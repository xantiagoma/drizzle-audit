  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vp pack",
    "test": "vp test run",
    "test:coverage": "vp test run --coverage",
    "test:coverage:open": "vp test run --coverage && open coverage/index.html",
    "lint": "vp lint",
    "lint:fix": "vp lint --fix",
    "format": "vp fmt",
    "format:check": "vp fmt --check",
    "check": "vp lint && vp fmt --check && tsc --noEmit",
    "release": "changelogen --release --push",
    "changelog": "changelogen",
    "prepare": "husky",
    "example:basic": "bun examples/basic/server.ts",
    "example:mongo": "bun examples/mongo/server.ts",
    "example:express": "bun examples/express-mysql-sqlite/server.ts"
  },
  "devDependencies": {
    "@electric-sql/pglite": "^0.4.5",
    "@types/express": "^5.0.6",
    "@vitest/coverage-v8": "4.1.6",
    "changelogen": "^0.6.2",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.2",
    "elysia": "^1.4.28",
    "express": "^5.2.1",
    "get-port-please": "^3.2.0",
    "hono": "^4.12.22",
    "husky": "^9.1.7",
    "mongodb": "^7.2.0",
    "mongodb-memory-server": "^11.1.0",
    "mysql-memory-server": "^1.14.1",
    "mysql2": "^3.22.3",
    "vite-plus": "^0.1.22"
  },
  "peerDependencies": {
    "drizzle-orm": ">= 0.33.0 < 2",
    "typescript": "^5"
  }
}
