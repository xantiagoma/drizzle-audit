{
  "name": "drizzle-audit",
  "version": "0.1.0",
  "description": "Configurable audit logging for Drizzle ORM",
  "keywords": [
    "audit",
    "audit-log",
    "audit-trail",
    "changelog",
    "database",
    "drizzle",
    "drizzle-orm",
    "history",
    "logging",
    "mysql",
    "postgresql",
    "sqlite",
    "tracking"
  ],
  "homepage": "https://github.com/xantiagoma/drizzle-audit#readme",
  "bugs": {
    "url": "https://github.com/xantiagoma/drizzle-audit/issues"
  },
  "license": "MIT",
  "author": "Santiago Montoya <xantiagoma@gmail.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/xantiagoma/drizzle-audit.git"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "dist/index.cjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.mts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./pg": {
      "import": {
        "types": "./dist/pg.d.mts",
